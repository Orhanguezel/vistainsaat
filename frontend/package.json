{
  "name": "vistainsaat-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3030 --webpack",
    "build": "next build",
    "start": "next start --port 3030",
    "start:standalone": "PORT=${PORT:-3030} HOSTNAME=${HOSTNAME:-127.0.0.1} node .next/standalone/server.js",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test:theme": "node scripts/check-theme-tokens.mjs",
    "test:seo": "node scripts/check-seo-smoke.mjs",
    "test:release": "node scripts/check-release-html.mjs",
    "test:smoke:admin-content": "node scripts/check-admin-content-flow.mjs",
    "test:media": "node scripts/check-media-seo.mjs",
    "audit:media": "node scripts/audit-media-seo.mjs",
    "audit:crawl": "node scripts/crawl-seo-report.mjs",
    "audit:lighthouse": "npx @lhci/cli autorun --config=./lighthouserc.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.20",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-intl": "^4.8.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5.8.0",
    "tailwindcss": "^4.1.0",
    "@tailwindcss/postcss": "^4.1.0",
    "postcss": "^8.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6"
  }
}
