{
  "name": "vistainsaat-backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun x tsc -p tsconfig.json && bun x tsc-alias -p tsconfig.json && node scripts/fix-esm-extensions.mjs",
    "start": "node --experimental-specifier-resolution=node dist/index.js",
    "start:bun": "bun dist/index.js",
    "db:seed": "node --experimental-specifier-resolution=node dist/db/seed/index.js --profile=vistainsaat",
    "db:seed:nodrop": "node --experimental-specifier-resolution=node dist/db/seed/index.js --profile=vistainsaat --no-drop",
    "db:seed:only": "node --experimental-specifier-resolution=node dist/db/seed/index.js --only=",
    "db:seed:full": "node --experimental-specifier-resolution=node dist/db/seed/index.js",
    "db:seed:full:nodrop": "node --experimental-specifier-resolution=node dist/db/seed/index.js --no-drop",
    "db:seed:vistainsaat": "node --experimental-specifier-resolution=node dist/db/seed/index.js --profile=vistainsaat --no-drop",
    "db:seed:vistainsaat:fresh": "node --experimental-specifier-resolution=node dist/db/seed/index.js --profile=vistainsaat",
    "test:smoke:vistainsaat-admin": "node scripts/smoke-vistainsaat-admin.mjs"
  },
  "dependencies": {
    "@fastify/cookie": "^11",
    "@fastify/cors": "^11",
    "@fastify/jwt": "^10",
    "@fastify/multipart": "^9",
    "@fastify/mysql": "^5.0.2",
    "@fastify/static": "^8.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.8.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.6",
    "fastify": "^5",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "2.0.0",
    "geoip-lite": "^1.4.10",
    "google-auth-library": "^10.4.1",
    "mysql2": "^3.15.3",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.11",
    "puppeteer": "^24.32.1",
    "ws": "^8.18.3",
    "zod": "3.23.8",
    "zod-to-json-schema": "3.23.2"
  },
  "devDependencies": {
    "@esbuild/linux-x64": "0.25.11",
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "20",
    "@types/nodemailer": "^7.0.4",
    "bun-types": "^1.3.1",
    "esbuild": "0.25.11",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "5"
  },
  "overrides": {
    "zod-to-json-schema": "3.23.2"
  },
  "resolutions": {
    "zod-to-json-schema": "3.23.2"
  }
}
