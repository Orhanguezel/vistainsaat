# =========================================================
# Genel
# =========================================================
PORT=8086
NODE_ENV=development

# =========================================================
# DB bağlantısı
# =========================================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app
DB_NAME=vistainsaat

# =========================================================
# Auth / login
# =========================================================
ALLOW_TEMP_LOGIN=0
TEMP_PASSWORD=change-me

JWT_SECRET=change-me-long-random-jwt-secret
COOKIE_SECRET=change-me-long-random-cookie-secret
AUTH_ADMIN_EMAILS=admin@example.com

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me

# =========================================================
# CORS
# =========================================================
CORS_ORIGIN=http://localhost:3004,http://localhost:3020,http://127.0.0.1:3004,http://127.0.0.1:3020

# =========================================================
# Storage / Upload
# =========================================================
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=/uploads
LOCAL_STORAGE_BASE_URL=/uploads
STORAGE_CDN_PUBLIC_BASE=
STORAGE_PUBLIC_API_BASE=http://localhost:8186

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=kompozit
CLOUDINARY_UNSIGNED_PRESET=
CLOUDINARY_UNSIGNED_UPLOAD_PRESET=

# =========================================================
# Mail / SMTP
# =========================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@example.com
SMTP_SECURE=false

# =========================================================
# URL’ler
# =========================================================
PUBLIC_URL=http://localhost:8186
FRONTEND_URL=http://localhost:3020
PUBLIC_API_BASE=http://localhost:8186

# =========================================================
# Google OAuth
# =========================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =========================================================
# Browser / Audit
# =========================================================
PUPPETEER_EXECUTABLE_PATH=
AUDIT_EXCLUDE_IPS=
